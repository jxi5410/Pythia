# Copy to .env and set real values locally. Do not commit .env.
NEWSAPI_KEY=
PYTHIA_API_KEY=
PYTHIA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PYTHIA_ALLOW_UNAUTHENTICATED=false
PYTHIA_RATE_LIMIT_REQUESTS=120
PYTHIA_RATE_LIMIT_WINDOW_SECONDS=60
PYTHIA_LATENCY_SAMPLE_SIZE=500

# ── LLM Configuration ──
# Backend: "openai" (default — works with Qwen, DeepSeek, Ollama), "claude", or "anthropic"
PYTHIA_LLM_BACKEND=openai

# For Qwen (Alibaba Bailian) — cheapest, recommended for development:
#   Get key: https://bailian.console.aliyun.com/
PYTHIA_LLM_API_KEY=
PYTHIA_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PYTHIA_LLM_MODEL=qwen-plus
PYTHIA_LLM_MODEL_STRONG=qwen-max

# For DeepSeek:
#   PYTHIA_LLM_BASE_URL=https://api.deepseek.com
#   PYTHIA_LLM_MODEL=deepseek-chat
#   PYTHIA_LLM_MODEL_STRONG=deepseek-reasoner

# For Ollama (local, free):
#   PYTHIA_LLM_BASE_URL=http://localhost:11434/v1
#   PYTHIA_LLM_API_KEY=ollama
#   PYTHIA_LLM_MODEL=qwen2.5:14b

# For Claude (requires Claude Max subscription + CLI):
#   PYTHIA_LLM_BACKEND=claude

# For Anthropic API directly:
#   PYTHIA_LLM_BACKEND=anthropic
#   PYTHIA_LLM_API_KEY=sk-ant-...
